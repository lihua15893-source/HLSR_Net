    print(f"输入尺寸: {x.shape}")

    # 前向传播
    with torch.no_grad():
        output = model(x)

    print(f"输出尺寸: {output.shape}")

    # 详细参数分析
    print("\n" + "=" * 50)
    model.analyze_parameters_detailed()

    print("\n🎉 分析完成！")
    print("=" * 50)


